generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ✅ 1. สร้าง Enum ล็อกค่าสถานะและสิทธิ
enum Role {
  ADMIN
  STAFF
}

enum OrderStatus {
  Pending
  Processing
  Ironing
  Delivery
  Completed
}

enum PaymentStatus {
  UNPAID
  PAID
}

// =======================
// USER (ADMIN / STAFF)
// =======================
model User {
  id       String @id @default(cuid())
  username String @unique
  password String

  role Role @default(ADMIN) // ✅ ใช้ Enum

  sessions  Session[]
  adminLogs AdminLog[]
  orderLogs OrderStatusLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// NEXTAUTH SESSION & TOKEN
// =======================
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// =======================
// CUSTOMER ORDER (หัวบิล)
// =======================
model Order {
  id           String  @id @default(cuid())
  customerId   String  @unique // ลูกค้าใช้ติดตามงาน เช่น GM-0001
  customerName String?
  note         String?

  // 1 ออเดอร์ มีเสื้อผ้าได้หลายชิ้น
  items OrderItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// ORDER ITEM (รายการเสื้อผ้าแต่ละชิ้น)
// =======================
model OrderItem {
  id       String @id @default(cuid())
  orderId  String
  itemName String // ชื่อเสื้อผ้า เช่น "เสื้อเชิ้ต", "กางเกง"
  status   String @default("รอซัก") // สถานะของชิ้นนี้

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  // ประวัติการเปลี่ยนสถานะของเสื้อผ้าชิ้นนี้
  statusLogs OrderStatusLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// =======================
// LOGS
// =======================
model AdminLog {
  id        String   @id @default(cuid())
  adminId   String
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  // เปลี่ยนชื่อจาก user เป็น admin ให้สอดคล้องกับ adminId
  admin User @relation(fields: [adminId], references: [id], onDelete: Cascade)
}

// ✅ รวม OrderStatusLog ให้เหลือตารางเดียว และผูกกับ OrderItem
model OrderStatusLog {
  id String @id @default(cuid())

  orderItemId String? // ✅ อนุญาตให้เป็น Null ได้เผื่อชิ้นงานถูกลบ
  oldStatus   String // ✅ เก็บเป็น String ไว้กัน Enum พังในอนาคต ถูกต้องครับ
  newStatus   String

  adminId String? // ✅ อนุญาตให้เป็น Null ได้เผื่อแอดมินถูกลบออกจากระบบ

  // ใช้ SetNull เพื่อให้ประวัติยังอยู่ แม้เสื้อผ้าหรือพนักงานจะถูกลบไปแล้ว
  admin User?      @relation(fields: [adminId], references: [id], onDelete: SetNull)
  item  OrderItem? @relation(fields: [orderItemId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([orderItemId])
}
